<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Nouvelle participation</h5>
        <a href="{{ path('app_participation_evenement_index') }}" class="btn btn-sm btn-outline-secondary">
            Retour
        </a>
    </div>
    <div class="card-body">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            <div class="row g-3">
                <div class="col-md-6">
                    {{ form_label(form.evenement, 'Evenement') }}
                    {{ form_widget(form.evenement, {'attr': {'class': 'form-select'}}) }}
                    {{ form_errors(form.evenement) }}
                </div>

                {% if user_type == 'etudiant' %}
                    <div class="d-none">
                        {{ form_widget(form.utilisateur) }}
                    </div>
                {% else %}
                    <div class="col-md-6">
                        {{ form_label(form.utilisateur, 'Utilisateur') }}
                        {{ form_widget(form.utilisateur, {'attr': {'class': 'form-select'}}) }}
                        {{ form_errors(form.utilisateur) }}
                    </div>
                {% endif %}

                <div class="col-md-6">
                    {{ form_label(form.statut, 'Statut') }}
                    {{ form_widget(form.statut, {'attr': {'class': 'form-select'}}) }}
                    {{ form_errors(form.statut) }}
                </div>

                <div class="col-md-6">
                    {{ form_label(form.dateInscription, 'Date inscription') }}
                    {{ form_widget(form.dateInscription, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.dateInscription) }}
                </div>

                <div class="col-md-6">
                    {{ form_label(form.heureArrivee, 'Heure arrivee') }}
                    {{ form_widget(form.heureArrivee, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.heureArrivee) }}
                </div>

                <div class="col-md-6">
                    {{ form_label(form.heureDepart, 'Heure depart') }}
                    {{ form_widget(form.heureDepart, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.heureDepart) }}
                </div>

                <div class="col-md-6">
                    {{ form_label(form.feedbackNote, 'Note') }}
                    {{ form_widget(form.feedbackNote, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.feedbackNote) }}
                </div>

                <div class="col-12">
                    {{ form_label(form.feedbackCommentaire, 'Commentaire') }}
                    {{ form_widget(form.feedbackCommentaire, {'attr': {'class': 'form-control', 'rows': 4}}) }}
                    {{ form_errors(form.feedbackCommentaire) }}
                </div>
            </div>

            <div class="d-flex justify-content-end mt-4">
                <button type="submit" class="btn btn-primary">
                    Creer
                </button>
            </div>

        {{ form_end(form) }}
    </div>
</div>
